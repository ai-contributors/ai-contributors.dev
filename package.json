{
  "name": "ai-contributors-dev",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=24 <25",
    "pnpm": "10.33.2"
  },
  "scripts": {
    "prepare": "husky",
    "predev": "pnpm prepare:spec",
    "dev": "astro dev",
    "setup:spec": "node scripts/setup-spec-source.mjs",
    "prepare:spec": "node scripts/generate-docs.mjs && node scripts/generate-spec-data.mjs",
    "validate:spec": "node scripts/validate-spec-source.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "test": "node --test tests/unit/*.test.mjs tests/integration/*.test.mjs",
    "test:dist": "node --test tests/built/*.test.mjs",
    "type-check": "astro check",
    "coverage:check": "vitest run --coverage",
    "prelhci:assert": "node scripts/prepare-lhci-dist.mjs",
    "lhci:assert": "lhci autorun --config .lighthouserc.cjs",
    "deps:check": "depcruise --config .dependency-cruiser.cjs astro.config.mjs src/content.config.ts scripts tests src/data && madge --extensions js,mjs,ts --circular astro.config.mjs src/content.config.ts scripts tests src/data",
    "secretlint:scan": "node scripts/secret-scan-tracked.mjs",
    "secret-scan": "pnpm secretlint:scan",
    "secret:scan": "pnpm secretlint:scan",
    "check:doc-nav": "node scripts/check-doc-nav.mjs",
    "check": "pnpm check:doc-nav && pnpm type-check",
    "build": "astro build && node scripts/generate-llms.mjs && pagefind --site dist --output-subdir pagefind && pnpm test:dist",
    "preview": "astro preview"
  },
  "dependencies": {
    "@astrojs/mdx": "5.0.6",
    "@astrojs/starlight": "0.39.2",
    "@fontsource/instrument-serif": "5.2.8",
    "astro": "6.3.7"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@eslint/js": "10.0.1",
    "@lhci/cli": "0.15.1",
    "@secretlint/secretlint-rule-preset-recommend": "13.0.2",
    "@vitest/coverage-v8": "4.1.7",
    "dependency-cruiser": "17.4.2",
    "eslint": "10.4.0",
    "github-slugger": "2.0.0",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "madge": "8.0.0",
    "pagefind": "1.5.2",
    "prettier": "3.8.3",
    "remark-custom-heading-id": "2.0.0",
    "remark-directive": "4.0.0",
    "secretlint": "13.0.2",
    "typescript": "6.0.3",
    "unist-util-visit": "5.1.0",
    "vitest": "4.1.7"
  },
  "pnpm": {
    "overrides": {
      "uuid": "14.0.0"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
}
