---
import { BADGE_LEVELS, badgeMarkdownForLevel } from "../data/badges";
---

<div class="badge-generator">
  <label for="badge-level">Conformance level</label>
  <select id="badge-level">
    {
      BADGE_LEVELS.map((level) => (
        <option value={level.id} selected={level.id === "L3"}>
          {level.id} - {level.name}
        </option>
      ))
    }
  </select>
  <textarea id="badge-markdown" rows="3" readonly>{badgeMarkdownForLevel("L3")}</textarea>
  <button type="button" id="copy-badge">Copy Markdown</button>
</div>

<script is:inline type="application/json" id="badge-level-data" set:html={JSON.stringify(BADGE_LEVELS)} />

<script>
  const select = document.getElementById("badge-level") as HTMLSelectElement | null;
  const output = document.getElementById("badge-markdown") as HTMLTextAreaElement | null;
  const copy = document.getElementById("copy-badge") as HTMLButtonElement | null;
  const data = document.getElementById("badge-level-data")?.textContent ?? "[]";
  const levels = JSON.parse(data) as Array<{ id: string; name: string; color: string }>;

  function markdownFor(levelId: string) {
    const level = levels.find((entry) => entry.id === levelId);
    if (!level) return "";
    const label = encodeURIComponent(`${level.id} ${level.name}`).replace(/%20/g, "%20");
    return `[![AI Contributor: ${level.id} ${level.name}](https://img.shields.io/badge/AI%20Contributor-${label}-${level.color})](https://ai-contributors.dev/ai-contributor-spec/)`;
  }

  select?.addEventListener("change", () => {
    if (!output) return;
    output.value = markdownFor(select.value);
  });

  copy?.addEventListener("click", async () => {
    if (!output) return;
    await navigator.clipboard.writeText(output.value);
    copy.textContent = "Copied";
    window.setTimeout(() => {
      copy.textContent = "Copy Markdown";
    }, 1400);
  });
</script>
