---
import Logo from '../components/Logo.astro';
import specSource from '../data/spec-source.generated.json';
import '../styles/design-tokens.css';
import '../styles/docs-styles.css';

interface Props {
  title: string;
  deck?: string;
  crumb: string;
  upstreamPath: string; // e.g. AI-CONTRIBUTOR-AUDIT-MODEL.md
  meta?: Array<{ label: string; value: string }>;
}

const { title, deck, crumb, upstreamPath, meta } = Astro.props;
const upstreamUrl = `https://github.com/ai-contributors/ai-contributor-spec/blob/${specSource.sha}/${upstreamPath}`;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const url = (path: string) => `${base}${path}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · ai-contributors / spec</title>
    <link rel="icon" href={url('/favicon.svg')} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="spec-canvas doc-body">
    <header class="doc-topbar">
      <div class="doc-topbar-inner">
        <a class="doc-brand" href={url('/')} aria-label="ai-contributors / spec">
          <Logo size={26} />
          <span class="doc-brand-name">ai-contributors</span>
          <span class="doc-brand-slash">/</span>
          <span class="doc-brand-doc">spec</span>
        </a>
        <span class="doc-crumb">
          <span class="doc-crumb-sep">›</span>
          {crumb}
        </span>
        <div class="doc-topbar-right">
          <a href={url('/specification/')}>Spec</a>
          <a href={upstreamUrl} rel="noopener">Source ↗</a>
        </div>
      </div>
    </header>

    <main class="doc-shell">
      <section class="doc-hero">
        <div class="doc-eyebrow">
          <span class="pill">{crumb}</span>
          <span>pinned to {specSource.shortSha}</span>
        </div>
        <h1 class="doc-title">{title}</h1>
        {deck && <p class="doc-deck">{deck}</p>}
        {
          meta && meta.length > 0 && (
            <div class="doc-meta">
              {meta.map((m) => (
                <span>
                  {m.label} <strong>{m.value}</strong>
                </span>
              ))}
            </div>
          )
        }
      </section>

      <article class="doc-content">
        <slot />
      </article>

      <footer class="doc-foot">
        <a href={url('/')}>← back to start</a>
        <a href={url('/specification/')}>Read the spec</a>
        <span class="right">
          rendered from <a href={upstreamUrl} rel="noopener">{upstreamPath}</a>
        </span>
      </footer>
    </main>
  </body>
</html>
