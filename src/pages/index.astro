---
import Logo from '../components/Logo.astro';
import specSource from '../data/spec-source.generated.json';
import '../styles/design-tokens.css';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const url = (path: string) => `${base}${path}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>ai-contributors / spec</title>
    <meta
      name="description"
      content="A vendor-neutral specification for AI-friendly codebases. The site renders the upstream spec verbatim — open the docs."
    />
    <link rel="icon" href={url('/favicon.svg')} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="spec-canvas landing">
    <main class="landing-shell">
      <div class="landing-mark">
        <Logo size={220} />
      </div>
      <p class="landing-eyebrow">Specification · {specSource.tag} · {specSource.shortSha}</p>
      <h1 class="landing-title">
        The AI Contributor<br />
        Specification.
      </h1>
      <p class="landing-tag">
        A vendor-neutral specification for AI-friendly codebases. This site renders the upstream
        repository verbatim.
      </p>
      <div class="landing-cta">
        <a class="btn-primary" href={url('/docs/')}>Open the docs →</a>
        <a
          class="btn-ghost"
          href="https://github.com/ai-contributors/ai-contributor-spec"
          rel="noopener">View on GitHub ↗</a
        >
      </div>
      <footer class="landing-foot">
        <a href={url('/specification/')}>Specification</a>
        <span class="dot">·</span>
        <a href={url('/audit/prompt/')}>No-install audit prompt</a>
        <span class="dot">·</span>
        <a
          href="https://creativecommons.org/licenses/by/4.0/"
          target="_blank"
          rel="noopener noreferrer">CC BY 4.0</a
        >
      </footer>
    </main>

    <style>
      body.landing {
        min-height: 100vh;
        display: grid;
        place-items: center;
        margin: 0;
        font-family: var(--sans);
        background: var(--paper);
        color: var(--ink);
      }
      .landing-shell {
        max-width: 720px;
        padding: 48px 32px;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4px;
      }
      .landing-mark {
        margin-bottom: 28px;
        padding: 24px;
        border: 1px solid var(--line);
        background: var(--paper-2);
        position: relative;
      }
      .landing-mark::before,
      .landing-mark::after {
        content: '';
        position: absolute;
        width: 8px;
        height: 8px;
        background: var(--ink);
      }
      .landing-mark::before {
        top: -4px;
        left: -4px;
      }
      .landing-mark::after {
        bottom: -4px;
        right: -4px;
      }
      .landing-eyebrow {
        font-family: var(--mono);
        font-size: 11px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--mute);
        margin: 0 0 18px;
        border: 1px solid var(--line);
        padding: 4px 10px;
      }
      .landing-title {
        font-family: var(--serif);
        font-weight: 400;
        font-size: clamp(40px, 6vw, 68px);
        line-height: 1;
        letter-spacing: -0.02em;
        margin: 0 0 22px;
      }
      .landing-tag {
        font-size: 17px;
        line-height: 1.5;
        color: var(--ink-2);
        margin: 0 0 32px;
        max-width: 52ch;
        text-wrap: pretty;
      }
      .landing-cta {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        justify-content: center;
        margin-bottom: 56px;
      }
      body.landing a.btn-primary,
      body.landing a.btn-ghost {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 12px 22px;
        font-family: var(--mono);
        font-size: 13px;
        border: 1px solid var(--ink);
        text-decoration: none;
        transition:
          transform 80ms ease,
          background 120ms ease;
      }
      body.landing a.btn-primary {
        background: var(--ink);
        color: var(--paper-2);
      }
      body.landing a.btn-primary:hover {
        background: var(--ink-2);
        text-decoration: none;
        transform: translateY(-1px);
      }
      body.landing a.btn-ghost {
        background: var(--paper-2);
        color: var(--ink);
      }
      body.landing a.btn-ghost:hover {
        background: var(--hover);
        text-decoration: none;
      }
      .landing-foot {
        display: flex;
        gap: 14px;
        flex-wrap: wrap;
        justify-content: center;
        font-family: var(--mono);
        font-size: 12px;
        color: var(--mute);
      }
      body.landing .landing-foot a {
        color: var(--mute);
        text-decoration: none;
      }
      body.landing .landing-foot a:hover {
        color: var(--ink);
        text-decoration: underline;
        text-underline-offset: 3px;
      }
      .landing-foot .dot {
        color: var(--line);
      }
    </style>
  </body>
</html>
