---
import Logo from '../components/Logo.astro';
import BadgeGenerator from '../components/BadgeGenerator.astro';
import specData from '../data/spec-data.generated.json';
import specSource from '../data/spec-source.generated.json';
import '../styles/design-tokens.css';
import '../styles/start-page.css';

// Site is served under a base path (e.g. /ai-contributor-spec/). Always
// resolve internal links against import.meta.env.BASE_URL so they keep
// working in dev and on Pages.
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const url = (path: string) => `${base}${path}`;

const { pillars, levels, version } = specData as {
  pillars: Array<{ id: string; num: string; icon: string; name: string; range: string; description: string }>;
  levels: Array<{ lvl: string; name: string; when: string }>;
  version: string;
};

const upstreamSkill = (name: string) =>
  `https://github.com/ai-contributors/ai-contributor-spec/blob/${specSource.sha}/skills/${name}/SKILL.md`;

const skills = [
  {
    tag: 'optional',
    id: 'ai-contributor-audit-profile',
    title: 'Profile',
    desc: "Describes the repo so the audit knows what it's looking at — stack, surfaces, deployment shape.",
    href: upstreamSkill('ai-contributor-audit-profile'),
    external: true,
  },
  {
    tag: 'required',
    id: 'ai-contributor-audit',
    title: 'Audit',
    desc: 'Runs the full audit pipeline. Collects evidence, stamps initial findings, hosts auditor judgments, validates the final report.',
    href: url('/skills/audit/'),
    external: false,
  },
  {
    tag: 'optional',
    id: 'ai-contributor-audit-fix',
    title: 'Fix',
    desc: 'Applies suggested improvements from the audit. Loops back into the audit skill to re-score.',
    href: upstreamSkill('ai-contributor-audit-fix'),
    external: true,
  },
];

const pipeline = [
  { label: 'audit-collect.ts', sub: 'evidence JSON' },
  { label: 'audit-stamp.ts', sub: 'initial pass' },
  { label: 'auditor edits', sub: 'judgment rows', human: true },
  { label: 'audit-stamp.ts', sub: 'final pass' },
  { label: 'audit-validate.ts', sub: 'read-only' },
];

const resources = [
  {
    kind: 'Audit',
    tag: 'no-install',
    title: 'Audit prompt',
    desc: 'A self-contained prompt you paste into any coding agent. Produces audit.md and evidence.json without installing the skill.',
    meta: 'no skills required',
    href: url('/audit/prompt/'),
  },
  {
    kind: 'Guide',
    tag: 'stack',
    title: 'TypeScript + pnpm',
    desc: 'Clause-by-clause walk-through for TypeScript repos using pnpm. What to put in AGENTS.md, what CI must do, and what passes at L0–L3.',
    meta: 'pnpm ≥ 9 · Node ≥ 20',
    href: url('/guide/typescript-pnpm/'),
  },
];

const installSnippet = `# install all three skills from the ai-contributors registry
$ npx skills add ai-contributors/ai-contributor-spec \\
    --skill ai-contributor-audit-profile \\
    --skill ai-contributor-audit \\
    --skill ai-contributor-audit-fix

  ✓ ai-contributor-audit-profile  (optional)  describes the repo
  ✓ ai-contributor-audit                       runs the audit loop
  ✓ ai-contributor-audit-fix      (optional)  applies improvements

→ next: invoke "ai-contributor-audit" from your agent`;

const updateSnippet = `# pull the latest audit prompts + spec data
$ npx skills update ai-contributor-audit

  ↻ ai-contributor-audit  v0.3.1 → v0.4.0
    · spec rev v0.1 → v0.2 (+3 clauses)
    · evidence collectors updated for monorepos
    · stamp format unchanged — prior audits remain valid`;

const invokeSnippet = `# from any agent that supports skills
  use skill: ai-contributor-audit-profile      # optional, run once
  use skill: ai-contributor-audit              # produces audit.md + evidence.json
  # — read the report, decide what to fix —
  use skill: ai-contributor-audit-fix          # optional, applies suggested edits
  use skill: ai-contributor-audit              # loop back to re-score`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>ai-contributors / spec</title>
    <meta
      name="description"
      content="Guardrails for repositories where AI reads, writes, reviews, or releases code. Seven pillars and five levels — from baseline hygiene to fully autonomous AI contributors."
    />
    <link rel="icon" href={url('/favicon.svg')} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="spec-canvas">
    <div class="page">
      <header class="topbar">
        <div class="topbar-inner">
          <a class="brand" href="#top" aria-label="ai-contributors / spec">
            <Logo size={28} />
            <span class="brand-name">ai-contributors</span>
            <span class="brand-slash">/</span>
            <span class="brand-doc">spec</span>
          </a>
          <nav class="topnav" aria-label="Primary">
            <a href="#install">Install</a>
            <a href="#audit">Audit</a>
            <a href="#levels">Levels</a>
            <a href="#pillars">Pillars</a>
            <a href="#resources">Resources</a>
            <a href={url('/specification/')}>Spec</a>
            <a
              href="https://github.com/ai-contributors/ai-contributor-spec"
              class="ghost-link"
              rel="noopener">GitHub ↗</a
            >
            <button type="button" class="theme-toggle" data-theme-toggle>Dark</button>
          </nav>
        </div>
      </header>

      <section id="top" class="hero">
        <div class="hero-grid">
          <div class="hero-mark">
            <Logo size={260} />
          </div>
          <div class="hero-copy">
            <div class="eyebrow">{version} · draft spec · {specSource.shortSha}</div>
            <h1 class="title">
              The contract between<br />humans and AI<br />contributors.
            </h1>
            <p class="manifesto">
              A spec for agent-friendly codebases. Seven pillars and five levels — from
              baseline hygiene to fully autonomous AI contributors.
            </p>
            <div class="cta-row">
              <a class="btn btn-primary" href={url('/specification/')}>Read the spec</a>
              <a class="btn btn-ghost" href="#install">
                <span class="mono">$ npx skills add ai-contributor-audit</span>
              </a>
            </div>
            <div class="hero-meta">
              <a
                class="license-chip"
                href="https://creativecommons.org/licenses/by/4.0/"
                target="_blank"
                rel="noopener noreferrer"
              >
                <span class="cc-glyphs mono" aria-hidden="true">CC&nbsp;BY&nbsp;4.0</span>
                <span class="license-name">Creative Commons Attribution 4.0 International</span>
              </a>
            </div>
          </div>
        </div>
      </section>

      <hr class="rule" />

      <section id="install" class="install">
        <div class="section-head">
          <span class="section-num">§ 01 · Install</span>
          <h2>Three skills. One audit loop.</h2>
          <p class="section-sub">
            Three skills installed via the <code>skills</code> CLI. Profile your repo, run the
            audit, optionally apply fixes, then loop until you hit your target level.
          </p>
        </div>

        <div class="install-grid">
          <div class="install-cli">
            <div class="cli-tabs" role="tablist" data-cli-tabs>
              <button
                type="button"
                role="tab"
                aria-selected="true"
                class="cli-tab is-on"
                data-tab="install"><span class="mono">$ skills add</span></button
              >
              <button
                type="button"
                role="tab"
                aria-selected="false"
                class="cli-tab"
                data-tab="update"><span class="mono">$ skills update</span></button
              >
              <button
                type="button"
                role="tab"
                aria-selected="false"
                class="cli-tab"
                data-tab="invoke"><span class="mono">agent</span></button
              >
            </div>
            <pre class="cli-block mono" data-tab-panel="install">{installSnippet}</pre>
            <pre class="cli-block mono" data-tab-panel="update" hidden>{updateSnippet}</pre>
            <pre class="cli-block mono" data-tab-panel="invoke" hidden>{invokeSnippet}</pre>
            <div class="cli-foot">
              <span>requires the <code>skills</code> CLI · node ≥ 20</span>
              <span>·</span>
              <a href="https://skills.sh" target="_blank" rel="noopener noreferrer">skills.sh ↗</a>
            </div>
          </div>

          <ol class="skill-list">
            {
              skills.map((s) => (
                <li class="skill">
                  <a
                    class="skill-link"
                    href={s.href}
                    {...(s.external ? { rel: 'noopener', target: '_blank' } : {})}
                  >
                    <div class="skill-head">
                      <span class={`skill-tag${s.tag === 'required' ? ' is-req' : ''}`}>
                        {s.tag}
                      </span>
                      <span class="skill-id">{s.id}</span>
                      {s.external && <span class="skill-ext mono">↗</span>}
                    </div>
                    <div class="skill-t">{s.title}</div>
                    <div class="skill-d">{s.desc}</div>
                  </a>
                </li>
              ))
            }
          </ol>
        </div>
      </section>

      <hr class="rule" />

      <section id="audit" class="audit">
        <div class="section-head">
          <span class="section-num">§ 02 · The audit loop</span>
          <h2>How the audit skill works.</h2>
          <p class="section-sub">
            The audit skill is a pipeline, not a single shot. It collects evidence, stamps an
            initial pass, hosts auditor judgments, runs a final pass, then validates the
            artifact — producing a reviewable report and a re-runnable loop.
          </p>
        </div>

        <div class="audit-diagram" role="img" aria-label="Audit pipeline diagram">
          <div class="audit-rail">
            <div class="node node-skill">
              <div class="node-head">skill</div>
              <div class="node-title">Profile</div>
              <div class="node-sub">optional</div>
            </div>
            <div class="arrow arrow-down" aria-hidden="true">↓</div>
            <div class="node node-skill node-skill-active">
              <div class="node-head">skill</div>
              <div class="node-title">Audit</div>
              <div class="node-sub">runs the pipeline</div>
            </div>
            <div class="arrow arrow-down" aria-hidden="true">↓</div>
          </div>

          <div class="audit-pipeline">
            {
              pipeline.map((n, i) => (
                <>
                  <div class={`node node-step${n.human ? ' node-human' : ''}`}>
                    <div class="node-head">step {String(i + 1).padStart(2, '0')}</div>
                    <div class="node-title">{n.label}</div>
                    <div class="node-sub">{n.sub}</div>
                    {n.human && <div class="node-flag">☆ human</div>}
                  </div>
                  {i < pipeline.length - 1 && (
                    <div class="arrow arrow-right" aria-hidden="true">
                      →
                    </div>
                  )}
                </>
              ))
            }
          </div>

          <div class="audit-rail">
            <div class="arrow arrow-down" aria-hidden="true">↓</div>
            <div class="node node-artifact">
              <div class="node-head">output</div>
              <div class="node-title">Reviewable audit artifacts</div>
              <div class="node-sub">filled MD · evidence JSON</div>
            </div>
            <div class="arrow arrow-down" aria-hidden="true">↓</div>
            <div class="audit-loopback">
              <div class="node node-skill">
                <div class="node-head">skill</div>
                <div class="node-title">Fix</div>
                <div class="node-sub">optional</div>
              </div>
              <div class="arrow arrow-loop" aria-hidden="true">↻ loop</div>
              <div class="node node-skill">
                <div class="node-head">skill</div>
                <div class="node-title">Audit</div>
                <div class="node-sub">re-score</div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <hr class="rule" />

      <section id="levels" class="levels">
        <div class="section-head">
          <span class="section-num">§ 03 · Levels</span>
          <h2>Five levels of AI autonomy.</h2>
          <p class="section-sub">
            Pick the minimum level your repo conforms to. The level a repository targets is
            determined by the highest AI workflow it permits, not by the average.
          </p>
        </div>

        <div class="levels-table" role="table">
          <div class="lvl-row lvl-head" role="row">
            <span role="columnheader">Min. level</span>
            <span role="columnheader">Name</span>
            <span role="columnheader">Autonomy</span>
            <span role="columnheader">Use this when…</span>
          </div>
          {
            levels.map((l, i) => {
              const pct = (i / (levels.length - 1)) * 100;
              return (
                <div class="lvl-row" role="row">
                  <span class="lvl-tag">{l.lvl}</span>
                  <span class="lvl-name">{l.name}</span>
                  <span class="lvl-auto">
                    <span class="lvl-bar"><span class="lvl-fill" style={`width:${pct}%`} /></span>
                    <span class="lvl-pct mono">{pct}%</span>
                  </span>
                  <span class="lvl-desc">{l.when}</span>
                </div>
              );
            })
          }
        </div>

        <div class="badge-block">
          <div class="badge-label">Display your level</div>
          <BadgeGenerator />
        </div>
      </section>

      <section class="big-msg">
        <div class="big-msg-inner">
          <div class="big-msg-eyebrow">⌘ Why this matters</div>
          <p class="big-msg-text">
            Create an <em>agent-friendly</em> codebase<br />
            with customized <u>Guardrails</u> &amp; <u>Harness</u>.
          </p>
          <div class="big-msg-foot">
            <span>↳ guardrails</span>
            <span>↳ harness</span>
            <span>↳ ship</span>
          </div>
        </div>
      </section>

      <hr class="rule" />

      <section id="pillars" class="pillars">
        <div class="section-head">
          <span class="section-num">§ 04 · Pillars</span>
          <h2>Seven pillars, twenty-nine clauses.</h2>
          <p class="section-sub">
            The spec is organised into seven pillars. Each one bundles a contiguous range of
            clauses that together govern one slice of an agent-friendly repo.
          </p>
        </div>
        <div class="pillars-grid">
          {
            pillars.map((p, i) => (
              <a class="pillar" href={url(`/specification/#p-${p.id}`)}>
                <div class="pillar-head">
                  <span class="pillar-k mono">{p.range}</span>
                  <span class="pillar-icon" aria-hidden="true">
                    {p.icon}
                  </span>
                </div>
                <h3>{p.name}</h3>
                <p>{p.description}</p>
                <div class="pillar-foot">
                  <span>pillar-0{i + 1}</span>
                  <span>→</span>
                </div>
              </a>
            ))
          }
        </div>
      </section>

      <hr class="rule" />

      <section id="resources" class="resources">
        <div class="section-head">
          <span class="section-num">§ 05 · Resources</span>
          <h2>Drop-in prompts and stack guides.</h2>
          <p class="section-sub">
            Companion documents alongside the specification. The audit prompt is the no-install
            path; the stack guides translate language-agnostic clauses into concrete artifacts
            for one ecosystem at a time.
          </p>
        </div>
        <ul class="resource-grid">
          {
            resources.map((it) => (
              <li class="resource-card">
                <a href={it.href} class="resource-link">
                  <div class="resource-head">
                    <span class="resource-kind">{it.kind}</span>
                    <span class="resource-tag">{it.tag}</span>
                  </div>
                  <div class="resource-title">{it.title}</div>
                  <p class="resource-desc">{it.desc}</p>
                  <div class="resource-foot">
                    <span>{it.meta}</span>
                    <span class="resource-arrow">Read →</span>
                  </div>
                </a>
              </li>
            ))
          }
        </ul>
      </section>

      <footer class="footer">
        <div class="footer-inner">
          <div class="footer-mark">
            <Logo size={44} />
            <div>
              <div class="footer-name">ai-contributors / spec</div>
              <div class="footer-sub">An open spec for human–agent collaboration.</div>
            </div>
          </div>
          <div class="footer-cols">
            <div>
              <div class="footer-h">Spec</div>
              <a href={url('/specification/')}>Full specification</a>
              <a href="#install">Install</a>
              <a href="#audit">Audit loop</a>
              <a href="#levels">Levels</a>
              <a href="#pillars">Pillars</a>
              <a href="#resources">Resources</a>
            </div>
            <div>
              <div class="footer-h">Source</div>
              <a href="https://github.com/ai-contributors/ai-contributor-spec">GitHub</a>
              <a href={specSource.commitUrl}>Pinned to {specSource.shortSha}</a>
              <a
                href="https://creativecommons.org/licenses/by/4.0/"
                target="_blank"
                rel="noopener noreferrer">CC BY 4.0</a
              >
            </div>
          </div>
        </div>
        <div class="footer-rule"></div>
        <div class="footer-bot">
          <span>© 2026 ai-contributors</span>
          <span>{version} · draft</span>
          <span>made by humans &amp; agents</span>
        </div>
      </footer>
    </div>

    <script is:inline>
      // CLI tabs
      const tabRoot = document.querySelector('[data-cli-tabs]');
      if (tabRoot) {
        tabRoot.addEventListener('click', (e) => {
          const target = e.target.closest('[data-tab]');
          if (!target) return;
          const key = target.dataset.tab;
          tabRoot.querySelectorAll('[data-tab]').forEach((b) => {
            const on = b.dataset.tab === key;
            b.classList.toggle('is-on', on);
            b.setAttribute('aria-selected', String(on));
          });
          document.querySelectorAll('[data-tab-panel]').forEach((p) => {
            p.hidden = p.dataset.tabPanel !== key;
          });
        });
      }

      // Theme toggle (persisted)
      const root = document.documentElement;
      const stored = localStorage.getItem('ac-theme');
      if (stored === 'dark') root.dataset.invert = '1';
      const btn = document.querySelector('[data-theme-toggle]');
      const sync = () => {
        const dark = root.dataset.invert === '1';
        if (btn) btn.textContent = dark ? 'Light' : 'Dark';
      };
      sync();
      btn?.addEventListener('click', () => {
        const dark = root.dataset.invert === '1';
        if (dark) {
          delete root.dataset.invert;
          localStorage.setItem('ac-theme', 'light');
        } else {
          root.dataset.invert = '1';
          localStorage.setItem('ac-theme', 'dark');
        }
        sync();
      });
    </script>
  </body>
</html>
